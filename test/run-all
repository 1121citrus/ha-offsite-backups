#!/usr/bin/env bash

# test/run-all — run the full ha-offsite-backups bats test suite.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Executes all bats test files inside a bats/bats:1.13.0 Docker container
# with the project source bind-mounted read-only.  No built image is required.
#
# SYNOPSIS
#   test/run-all [BATS_ARGS...]
#
# EXAMPLES
#   # Run all tests
#   test/run-all
#
#   # Run with verbose output
#   test/run-all --verbose
#
#   # Run a single test file
#   test/run-all test/02-ha-offsite-backups.bats

set -euo pipefail

script_dir=$(dirname "$(readlink -f "$0")")
repo_root=$(dirname "${script_dir}")

exec docker run --rm -i \
    -v "${repo_root}:/code:ro" \
    -w /code \
    bats/bats:1.13.0 \
        test/00-noop.bats \
        test/01-dockerfile.bats \
        test/02-ha-offsite-backups.bats \
        test/03-build.bats \
        test/04-image-metadata.bats \
        test/05-common-functions.bats \
        test/06-healthcheck.bats \
        test/07-ha-offsite-backups-coverage.bats \
        "$@"
