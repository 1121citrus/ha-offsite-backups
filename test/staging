#!/usr/bin/env bash

# test/staging — functional tests for ha-offsite-backups against live AWS.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# These tests exercise the ha-offsite-backups CLI end-to-end with no stubs.
# Tests that require a live S3 bucket are skipped (not failed) when BUCKET
# is unset or AWS credentials are unavailable.
#
# IAM permissions required:
#   Production tests (test_staging_cli_dryrun, test_staging_cron_fires):
#     s3:ListBucket       on arn:aws:s3:::${BUCKET}
#     s3:ListBucket       on arn:aws:s3:::${BUCKET}/*
#   End-to-end correctness test (test_staging_sync_e2e):
#     All of the above PLUS on arn:aws:s3:::test.staging.backups.ha-offsite-backups-*:
#     s3:CreateBucket, s3:DeleteBucket
#     s3:PutObject, s3:GetObject, s3:ListBucket, s3:DeleteObject
#
# SYNOPSIS
#   test/staging [options] [IMAGE]
#
# OPTIONS
#   IMAGE                     Docker image to test (positional; also --image)
#   --image IMAGE             Docker image to test (env: IMAGE)
#   --bucket BUCKET           S3 bucket to sync to
#                             (env: HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME,
#                             AWS_S3_BUCKET_NAME)
#   --bucket-list LIST        Space-separated bucket list (env: BUCKET_LIST)
#   --aws-config FILE         AWS config file path
#                             (env: AWS_CONFIG_FILE;
#                             default: ~/.secrets/aws-config)
#   --aws-credentials FILE    AWS credentials file path
#                             (env: AWS_CREDENTIALS_FILE;
#                             default: ~/.secrets/aws-credentials)
#   --dryrun                  Enable dry-run for production bucket tests
#                             (env: DRYRUN; default: true)
#   --no-dryrun               Disable dry-run for production bucket tests
#   --scan                    Run Trivy HIGH/CRITICAL scan on the image
#                             (env: STAGING_SCAN; default: true)
#   --no-scan                 Skip Trivy scan; also implies --no-advise unless
#                             --advise is given explicitly
#   --no-coverage             Skip the kcov bash coverage report (advisory only).
#   --advise [ADVISEMENTS]    Run advisory scans. Comma-delimited list:
#                             'coverage', 'grype', 'scout', 'dive', 'all', or
#                             any combination. 'all' selects every available
#                             advisement. Default with no list given: 'grype,scout'.
#                             Advisory scans are off by default.
#   --no-advise               Skip all advisory scans (Coverage, Grype, Scout, and Dive)
#   --cache CACHE_RULES       One-run cache controls for scanner DBs.
#                             Rule format: 'reset=<targets>;skip-update=<targets>'
#                             Targets: trivy, grype, all (comma-delimited)
#                             Examples:
#                               --cache 'reset=all'
#                               --cache 'skip-update=grype'
#                               --cache 'reset=grype;skip-update=trivy'
#   --yes                     Skip the "yes" confirmation prompt
#   --skip-e2e                Skip test_staging_sync_e2e
#   --test TEST               Run only the named test function
#   -h, --help                Print this message and exit
#
# ENVIRONMENT
#   Each variable may be overridden by an HA_OFFSITE_BACKUPS_-prefixed form
#   (e.g. HA_OFFSITE_BACKUPS_IMAGE); the prefixed form takes priority.
#   IMAGE / HA_OFFSITE_BACKUPS_IMAGE
#                      Docker image to test
#   AWS_S3_BUCKET_NAME / HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME
#                      S3 bucket to sync to (single bucket)
#   BUCKET_LIST / HA_OFFSITE_BACKUPS_BUCKET_LIST
#                      Space-separated list of buckets (default: AWS_S3_BUCKET_NAME)
#   AWS_CONFIG_FILE / HA_OFFSITE_BACKUPS_AWS_CONFIG_FILE
#                      Path to AWS config file
#   AWS_CREDENTIALS_FILE / HA_OFFSITE_BACKUPS_AWS_CREDENTIALS_FILE
#                      Path to AWS credentials file
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
#                      Inline AWS credentials (alternative to config/credentials
#                      files)
#   DRYRUN / HA_OFFSITE_BACKUPS_DRYRUN
#                      true = dry-run for production bucket tests (default)
#                      false = live deletions (test/staging buckets only)
#   STAGING_SCAN / HA_OFFSITE_BACKUPS_STAGING_SCAN
#                      true/false — controls Trivy scan (default: true)
#   DOCKER_RUN_ARGS / HA_OFFSITE_BACKUPS_DOCKER_RUN_ARGS
#                      Extra flags appended to every docker run invocation
#
# EXAMPLES
#   # AWS-independent smoke tests (no credentials needed):
#   test/staging 1121citrus/ha-offsite-backups:latest
#
#   # Quick iteration — skip scan and advise:
#   test/staging --no-scan 1121citrus/ha-offsite-backups:latest
#
#   # Skip Trivy but still run Grype advisory:
#   test/staging --no-scan --advise grype 1121citrus/ha-offsite-backups:latest
#
#   # Run only Grype advisory (skip Scout):
#   test/staging --advise grype 1121citrus/ha-offsite-backups:latest
#
#   # Run all three advisements: Grype, Scout, and Dive:
#   test/staging --advise grype,scout,dive 1121citrus/ha-offsite-backups:latest
#
#   # Reset scanner DB caches for this run, then skip Grype DB update:
#   test/staging --cache 'reset=all;skip-update=grype' 1121citrus/ha-offsite-backups:latest
#
#   # Full test suite against a dedicated test bucket:
#   test/staging --bucket test.my-backups \
#       --aws-config ~/.secrets/aws-config \
#       1121citrus/ha-offsite-backups:latest
#
#   # Skip confirmation prompt (CI / scripted use):
#   test/staging --bucket test.my-backups --yes \
#       1121citrus/ha-offsite-backups:latest
#
#   # Run only the end-to-end sync correctness test:
#   test/staging --bucket test.my-backups \
#       --test test_staging_sync_e2e \
#       1121citrus/ha-offsite-backups:latest
#
#   # Skip e2e test when credentials lack s3:CreateBucket:
#   test/staging --bucket my-backups --skip-e2e \
#       1121citrus/ha-offsite-backups:latest

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults — overridden by environment variables, then by CLI flags.
# ---------------------------------------------------------------------------
IMAGE="${HA_OFFSITE_BACKUPS_IMAGE-${IMAGE:-}}"
S3_BUCKET_NAME="${HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME-${AWS_S3_BUCKET_NAME:-}}"
BUCKET_LIST="${HA_OFFSITE_BACKUPS_BUCKET_LIST-${BUCKET_LIST:-}}"
AWS_CONFIG_FILE="${HA_OFFSITE_BACKUPS_AWS_CONFIG_FILE-${AWS_CONFIG_FILE:-}}"
AWS_CREDENTIALS_FILE="${HA_OFFSITE_BACKUPS_AWS_CREDENTIALS_FILE-${AWS_CREDENTIALS_FILE:-}}"
DRYRUN="${HA_OFFSITE_BACKUPS_DRYRUN-${DRYRUN:-true}}"
_YES="${HA_OFFSITE_BACKUPS_YES-false}"
_SKIP_E2E=false
_ONLY_TEST=""
_SCAN="${HA_OFFSITE_BACKUPS_STAGING_SCAN-${STAGING_SCAN:-true}}"
_ADVISE_COVERAGE=false
_ADVISE_DIVE=false
_ADVISE_GRYPE=false
_ADVISE_SCOUT=false
_ADVISE_EXPLICIT=false   # set to true when --advise or --no-advise is passed
_CACHE_RESET_TRIVY=false
_CACHE_RESET_GRYPE=false
_CACHE_SKIP_UPDATE_TRIVY=false
_CACHE_SKIP_UPDATE_GRYPE=false
DOCKER_RUN_ARGS="${HA_OFFSITE_BACKUPS_DOCKER_RUN_ARGS-${DOCKER_RUN_ARGS:-}}"

# Tool image refs — keep in sync with the top-level build script.
BATS_KCOV_IMAGE=1121citrus/bats-kcov
BATS_KCOV_TAG=latest
DIVE_IMAGE=wagoodman/dive
DIVE_TAG=v0.13.1
GRYPE_IMAGE=anchore/grype
GRYPE_TAG=v0.87.0
TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.62.1

# Named Docker volumes for scanner DB caches (avoid host-path coupling).
TRIVY_CACHE_VOLUME=ha-offsite-backups-staging-trivy-cache
GRYPE_CACHE_VOLUME=ha-offsite-backups-staging-grype-cache

_set_cache_targets() {
    local mode="$1" targets_csv="$2" target
    IFS=',' read -ra _tgts <<< "${targets_csv,,}"
    for target in "${_tgts[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_TRIVY=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_TRIVY=true; fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_GRYPE=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_GRYPE=true; fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_TRIVY=true; _CACHE_RESET_GRYPE=true
                fi
                if [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_TRIVY=true; _CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *) echo "Unknown cache target: ${target}" >&2; exit 1 ;;
        esac
    done
}

_parse_cache_rules() {
    local rules="$1" entry key value
    IFS=';' read -ra _rules <<< "${rules}"
    for entry in "${_rules[@]}"; do
        key="${entry%%=*}"; value="${entry#*=}"
        key="${key,,}"; key="${key// /}"; value="${value// /}"
        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2; exit 1
        fi
        case "${key}" in
            reset|skip-update) _set_cache_targets "${key}" "${value}" ;;
            *) echo "Unknown --cache rule key: ${key}" >&2; exit 1 ;;
        esac
    done
}

_reset_cache_db() {
    local volume_name="$1"
    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.21 \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

show_help() {
    # Extract the header comment from SYNOPSIS through EXAMPLES (inclusive).
    sed -n '/^# SYNOPSIS/,/^set -/p' "$0" \
        | grep '^#' \
        | sed 's/^# \{0,1\}//'
}

setup() {
    [[ -n "${IMAGE}" ]] || {
        echo "ERROR: IMAGE is not set" >&2
        echo "       Pass it as a positional arg or use --image IMAGE" >&2
        return 1
    }
    docker image inspect "${IMAGE}" > /dev/null 2>&1 || {
        echo "ERROR: image not found locally: ${IMAGE}" >&2
        echo "       Pull or build it first: ./build --no-scan" >&2
        return 1
    }

    # Verify the image uses the exec-form ENTRYPOINT, not the legacy
    # shell-form ENTRYPOINT ["/bin/sh","-c"] + CMD ["/usr/local/bin/startup"].
    # With the legacy form, CLI args like --help replace CMD and are passed to
    # /bin/sh as options, causing all CLI-flag tests to fail with exit 2.
    local ep
    ep=$(docker inspect "${IMAGE}" --format '{{json .Config.Entrypoint}}' \
             2>/dev/null || echo "")
    if [[ "${ep}" != '["/usr/local/bin/ha-offsite-backups"]' ]]; then
        echo "ERROR: unexpected ENTRYPOINT in ${IMAGE}" >&2
        echo "       Got:      ${ep}" >&2
        echo "       Expected: [\"/usr/local/bin/ha-offsite-backups\"]" >&2
        echo "       The Hub image is stale. Rebuild and test against the" >&2
        echo "       local dev image: ./build --no-scan" >&2
        return 1
    fi

    # Verify the entrypoint exists before any test runs.
    # Exit 127 from individual tests is confusing; a clear setup failure
    # is not.  This catches a stale 'latest' image before publishing a new
    # version — rebuild with: IMAGE=... ./build --no-scan
    if ! docker run --rm --entrypoint test "${IMAGE}" \
            -x /usr/local/bin/ha-offsite-backups > /dev/null 2>&1; then
        echo "ERROR: /usr/local/bin/ha-offsite-backups not found in ${IMAGE}" >&2
        echo "       Rebuild: ./build --no-scan" >&2
        return 1
    fi

    # Resolve the AWS config file path once so each test does not re-derive it.
    _aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"

    # The image runs as a non-root user (UID 10001).  A mode-600 file owned by
    # the host user is unreadable inside the container.  Create a world-readable
    # temp copy for the duration of the test run.
    _aws_cfg_mount="${_aws_cfg}"
    if [[ -r "${_aws_cfg}" ]]; then
        _aws_cfg_mount=$(mktemp /tmp/aws-config-staging-XXXXXX)
        cp "${_aws_cfg}" "${_aws_cfg_mount}"
        chmod 0644 "${_aws_cfg_mount}"
    fi
    export _aws_cfg_mount

    # Resolve the AWS credentials file; create a world-readable temp copy for
    # the non-root container user (UID 10001), same as the config file above.
    _aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    _aws_creds_mount="${_aws_creds}"
    if [[ -r "${_aws_creds}" ]]; then
        _aws_creds_mount=$(mktemp /tmp/aws-credentials-staging-XXXXXX)
        cp "${_aws_creds}" "${_aws_creds_mount}"
        chmod 0644 "${_aws_creds_mount}"
    fi
    export _aws_creds _aws_creds_mount

    # Run ha-offsite-backups with staging credentials and the given CLI args.
    # Set _backup_dir before calling to mount a local directory at /backups.
    # No stubs: the real AWS CLI and real S3 bucket are used.
    # stderr is merged with stdout so callers capture all log output.
    run_ha_offsite_backups() {
        local aws_mounts=() aws_env=() backup_mounts=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        [[ -n "${_backup_dir:-}" ]] && \
            backup_mounts+=(-v "${_backup_dir}:/backups:ro")
        # shellcheck disable=SC2086
        docker run --rm ${DOCKER_RUN_ARGS:-} \
            -e "HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME=${S3_BUCKET_NAME:-}" \
            -e "DRYRUN=${DRYRUN:-true}" \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            "${backup_mounts[@]}" \
            "${IMAGE}" "$@" 2>&1
    }

    # Start the full service container (scheduler mode) detached.
    # Prints the container ID to stdout; caller is responsible for stop and rm.
    run_service_detached() {
        local aws_mounts=() aws_env=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        # shellcheck disable=SC2086
        docker run -d ${DOCKER_RUN_ARGS:-} \
            -e "HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME=${S3_BUCKET_NAME:-}" \
            -e "DRYRUN=${DRYRUN:-true}" \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            "$@" \
            "${IMAGE}"
    }

    # Run an aws CLI command inside the image, bypassing the ha-offsite-backups
    # entrypoint.  Used for bucket setup/teardown in test_staging_sync_e2e.
    _aws() {
        local aws_mounts=() aws_env=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        # shellcheck disable=SC2086
        docker run --rm --entrypoint /usr/bin/aws \
            ${DOCKER_RUN_ARGS:-} \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            -e "AWS_RETRY_MODE=standard" \
            -e "AWS_MAX_ATTEMPTS=5" \
            "${IMAGE}" "$@"
    }

    export _aws_cfg _aws_cfg_mount _aws_creds _aws_creds_mount
    export -f _aws run_ha_offsite_backups run_service_detached

    # Create a shared image archive for Trivy, Grype, and Dive — avoids mounting
    # the Docker socket inside scanner containers, which hangs on macOS Docker Desktop.
    _scan_tar=""
    if [[ "${_SCAN}" == "true" || "${_ADVISE_GRYPE}" == "true" \
            || "${_ADVISE_DIVE}" == "true" ]]; then
        _scan_tar=$(mktemp /tmp/staging-scan-XXXXXX)
        docker save "${IMAGE}" > "${_scan_tar}"
    fi
    export _scan_tar

    # Clean up temp files on exit (world-readable credential copies + scan archive).
    # shellcheck disable=SC2064
    trap 'rm -f "${_aws_cfg_mount}" "${_aws_creds_mount}" "${_scan_tar}"' EXIT
}


# _skip prints a SKIP notice, increments the shared skip counter, and returns 0
# so the test is not counted as a failure.
_SKIP_COUNT=0
_skip() {
    echo "SKIP '${FUNCNAME[1]}': $*"
    (( ++_SKIP_COUNT )) || true
}

# _aws_available returns 0 when a bucket and at least one form of AWS
# credentials are present.
_aws_available() {
    local bucket="${S3_BUCKET_NAME:-${BUCKET_LIST:-}}"
    [[ -n "${bucket}" ]] && {
        [[ -r "${_aws_cfg:-/nonexistent}" ]] || \
        [[ -r "${_aws_creds:-/nonexistent}" ]] || \
        [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]
    }
}

# ── AWS-independent tests ─────────────────────────────────────────────────────
# These exercise CLI option parsing only; no bucket connection is attempted.

test_staging_help() {
    local output result=0
    output=$(run_ha_offsite_backups --help 2>&1) || result=$?
    if [[ ${result} -eq 0 ]] && echo "${output}" | grep -q 'Usage:'; then
        echo "PASS '${FUNCNAME[0]}': --help exits 0 and prints usage"
    else
        echo "FAIL '${FUNCNAME[0]}': --help failed (exit=${result})"
        return 1
    fi
}

test_staging_version() {
    local output result=0
    output=$(run_ha_offsite_backups --version 2>&1) || result=$?
    if [[ ${result} -eq 0 ]] && [[ -n "${output}" ]]; then
        echo "PASS '${FUNCNAME[0]}': --version exits 0 and prints: ${output}"
    else
        echo "FAIL '${FUNCNAME[0]}': --version failed (exit=${result})"
        return 1
    fi
}

test_staging_unknown_option() {
    local result=0
    run_ha_offsite_backups --no-such-option > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero for unknown option"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero for unknown option"
        return 1
    fi
}

test_staging_no_bucket_cli_mode() {
    # Run with no BUCKET env so the no-bucket error path is genuinely exercised.
    # Uses plain docker run (not run_ha_offsite_backups) to avoid injecting the
    # caller's BUCKET from the outer environment.
    local result=0
    docker run --rm "${IMAGE}" > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': CLI mode without bucket exits non-zero"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero without bucket"
        return 1
    fi
}

test_staging_cron_no_bucket() {
    # Scheduler mode must also validate bucket presence before exec'ing crond.
    # Uses plain docker run for the same reason as test_staging_no_bucket_cli_mode.
    local result=0
    docker run --rm "${IMAGE}" --cron > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': --cron without bucket exits non-zero"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero without bucket"
        return 1
    fi
}

# test_staging_cron_startup: verify the scheduler container starts, writes its
# crontab, and stays running — no AWS credentials required.
# Catches Dockerfile permission regressions (e.g. /var/spool/cron/crontabs
# root-owned via Alpine symlink) that CLI-mode tests cannot exercise.
test_staging_cron_startup() {
    local container_id
    # Use @daily so the job never fires during the test window.
    # shellcheck disable=SC2086
    container_id=$(docker run -d ${DOCKER_RUN_ARGS:-} \
        -e "AWS_S3_BUCKET_NAME=test.fake-bucket-for-startup-test" \
        -e "CRON_EXPRESSION=@daily" \
        "${IMAGE}")
    printf '  container %s started; waiting for scheduler init...\n' \
        "${container_id:0:12}" >&2

    sleep 3

    local running
    running=$(docker inspect --format '{{.State.Running}}' "${container_id}" \
        2>/dev/null || echo "false")

    local crontab_ok=false
    if [[ "${running}" == "true" ]]; then
        docker exec "${container_id}" \
            test -f /var/spool/cron/crontabs/ha-offsite-backups \
            > /dev/null 2>&1 && crontab_ok=true
    fi

    docker stop "${container_id}" > /dev/null 2>&1
    docker rm   "${container_id}" > /dev/null 2>&1

    if [[ "${running}" != "true" ]]; then
        echo "FAIL '${FUNCNAME[0]}': container exited within 3s of startup"
        return 1
    fi
    if ! "${crontab_ok}"; then
        echo "FAIL '${FUNCNAME[0]}': crontab file not found" \
             "(crontabs directory likely root-owned)"
        return 1
    fi
    echo "PASS '${FUNCNAME[0]}': scheduler running and crontab written"
}

# ── AWS-dependent tests ───────────────────────────────────────────────────────
# Each test skips when BUCKET/BUCKET_LIST or credentials are absent.

# test_staging_cli_dryrun: run one sync pass (CLI mode) with DRYRUN=true.
# Verifies the full find → rename → aws s3 sync --dryrun pipeline end-to-end.
# No objects are uploaded.  Expected duration: 10–60 s depending on bucket size.
test_staging_cli_dryrun() {
    _aws_available || { _skip "BUCKET or credentials not configured"; return 0; }

    printf '  starting CLI dry-run sync (DRYRUN=%s)...\n' \
        "${DRYRUN:-true}" >&2

    local output result=0
    output=$(run_ha_offsite_backups 2>&1) || result=$?

    if [[ ${result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': sync exited non-zero (${result})"
        printf '  -- full output --\n' >&2
        printf '%s\n' "${output}" >&2
        printf '  -- end output --\n' >&2
        return 1
    fi
    if echo "${output}" | grep -q 'completed sync'; then
        echo "PASS '${FUNCNAME[0]}': CLI sync completed (DRYRUN=${DRYRUN:-true})"
    else
        echo "FAIL '${FUNCNAME[0]}': 'completed sync' not found in output"
        printf '  -- full output --\n' >&2
        printf '%s\n' "${output}" >&2
        printf '  -- end output --\n' >&2
        return 1
    fi
}

# test_staging_cron_fires: start the full scheduler container and wait for the
# cron daemon to trigger a complete sync cycle.
# Expected duration: up to 4 m (≤60 s to first cron tick + sync run time).
test_staging_cron_fires() {
    _aws_available || { _skip "BUCKET or credentials not configured"; return 0; }

    # Schedule every minute so the first fire is at most 60 s away.
    local container_id
    container_id=$(run_service_detached -e "CRON_EXPRESSION=* * * * *")
    printf '  container %s started; waiting for first cron sync (up to 2m)...\n' \
        "${container_id:0:12}" >&2

    local elapsed=0 timeout=120 interval=10 found=false last_log
    while [[ ${elapsed} -lt ${timeout} ]]; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        if docker logs "${container_id}" 2>&1 | grep -q 'completed sync'; then
            found=true
            break
        fi
        last_log=$(docker logs --tail 1 "${container_id}" 2>&1)
        printf '  [%ds] waiting... (last: %s)\n' "${elapsed}" "${last_log}" >&2
    done

    docker stop "${container_id}" > /dev/null 2>&1
    docker rm   "${container_id}" > /dev/null 2>&1

    if "${found}"; then
        echo "PASS '${FUNCNAME[0]}': cron sync completed within ${elapsed}s (DRYRUN=${DRYRUN:-true})"
    else
        echo "FAIL '${FUNCNAME[0]}': sync did not complete within ${timeout}s"
        return 1
    fi
}

# test_staging_sync_e2e: the only test that validates rename-and-sync correctness.
#
# Creates a disposable bucket named test.staging.backups.ha-offsite-backups-<epoch>,
# creates two synthetic HA backup files in a temp directory, mounts that directory
# as /backups, and runs ha-offsite-backups with DRYRUN=false.  Verifies that the
# renamed ISO-format keys appear in the bucket.
#
# Expected S3 keys after sync:
#   20250706T053500-home-assistant-automatic-backup-2025.6.3.tar
#   20250801T030000-home-assistant-automatic-backup-2025.6.4.tar
#
# The temp directory and bucket are always removed in a RETURN trap.
# This test always runs DRYRUN=false on its own transient bucket; the caller's
# DRYRUN env var does not apply here.
#
# Required IAM permissions (beyond production): s3:CreateBucket, s3:PutObject,
# s3:DeleteBucket on arn:aws:s3:::test.staging.backups.ha-offsite-backups-*
test_staging_sync_e2e() {
    _aws_available || { _skip "BUCKET or credentials not configured"; return 0; }

    local epoch test_bucket backup_dir
    epoch=$(date +%s)
    test_bucket="test.staging.backups.ha-offsite-backups-${epoch}"
    backup_dir=$(mktemp -d)

    # Always clean up the temp dir and transient bucket on exit — expand
    # variables now so they are captured in the trap string.
    # shellcheck disable=SC2064
    trap "rm -rf '${backup_dir}'; _aws s3 rb 's3://${test_bucket}' --force > /dev/null 2>&1 || true" RETURN

    # ── Populate local backup dir ─────────────────────────────────────────────
    # Two files with known HA backup names; the rename transform applied by
    # ha-offsite-backups must produce the expected ISO-format keys.
    local f1 f2 k1 k2
    f1="Automatic_backup_2025.6.3_2025-07-06_05.35_00004800.tar"
    f2="Automatic_backup_2025.6.4_2025-08-01_03.00_00004800.tar"
    k1="20250706T053500-home-assistant-automatic-backup-2025.6.3.tar"
    k2="20250801T030000-home-assistant-automatic-backup-2025.6.4.tar"
    touch "${backup_dir}/${f1}" "${backup_dir}/${f2}"
    printf '  created 2 synthetic HA backup files in %s...\n' "${backup_dir}" >&2

    # ── Create bucket ─────────────────────────────────────────────────────────
    printf '  creating transient test bucket s3://%s...\n' "${test_bucket}" >&2
    _aws s3 mb "s3://${test_bucket}" > /dev/null 2>&1 || {
        echo "FAIL '${FUNCNAME[0]}': could not create bucket" \
             "(check s3:CreateBucket on test.staging.backups.ha-offsite-backups-*)"
        return 1
    }

    # ── Sync ──────────────────────────────────────────────────────────────────
    # DRYRUN=false is unconditional — the point of this test is live upload to
    # the transient bucket.  YES=true skips the tty-only confirmation prompt.
    printf '  running live sync (DRYRUN=false)...\n' >&2
    local sync_output sync_result=0
    local aws_mounts=() aws_env=()
    if [[ -r "${_aws_cfg_mount}" ]]; then
        aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
        aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
    fi
    if [[ -r "${_aws_creds_mount}" ]]; then
        aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
        aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
    fi
    # shellcheck disable=SC2086
    sync_output=$(docker run --rm ${DOCKER_RUN_ARGS:-} \
        -e "HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME=${test_bucket}" \
        -e "DRYRUN=false" \
        -e "YES=true" \
        "${aws_mounts[@]}" \
        "${aws_env[@]}" \
        -v "${backup_dir}:/backups:ro" \
        "${IMAGE}" 2>&1) || sync_result=$?

    if [[ ${sync_result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': sync exited non-zero (${sync_result})"
        printf '%s\n' "${sync_output}" | tail -10 >&2
        return 1
    fi

    # ── Verify ────────────────────────────────────────────────────────────────
    # Both renamed keys must appear in the bucket.
    local bucket_listing missing=()
    bucket_listing=$(_aws s3 ls "s3://${test_bucket}/" 2>/dev/null)
    echo "${bucket_listing}" | grep -q "${k1}" || missing+=("${k1}")
    echo "${bucket_listing}" | grep -q "${k2}" || missing+=("${k2}")

    if [[ ${#missing[@]} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': 2 HA backups synced with correct ISO-format keys"
    else
        echo "FAIL '${FUNCNAME[0]}': missing expected S3 keys: ${missing[*]}"
        printf 'Bucket contents:\n' >&2
        printf '%s\n' "${bucket_listing}" >&2
        printf 'Sync output (last 10 lines):\n' >&2
        printf '%s\n' "${sync_output}" | tail -10 >&2
        return 1
    fi
}

