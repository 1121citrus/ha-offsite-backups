#!/usr/bin/env bash
# shellcheck shell=bash

# Mock aws CLI for ha-offsite-backups bats tests.
# Supports: s3 sync
# Records invocations to AWS_MOCK_SYNC_LOG for test assertions.

set -o errexit -o nounset -o pipefail

cmd="${1:-}"; shift || true
sub="${1:-}"; shift || true

if [[ "${cmd}" = "s3" && "${sub}" = "sync" ]]; then
    # Record the full argument list so tests can assert on flag presence
    # and destination bucket.
    logfile="${AWS_MOCK_SYNC_LOG:-/tmp/aws-sync.log}"
    echo "$*" >> "${logfile}"
    echo "(mock) sync: $*"
    exit 0
fi

echo "aws mock: unsupported command: ${cmd} ${sub} $*" >&2
exit 2
