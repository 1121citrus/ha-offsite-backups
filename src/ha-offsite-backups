# SYNOPSIS
#   ha-offsite-backups [options]
#
# DESCRIPTION
#   Rename Home Assistant automated backups to ISO-datetime order and sync
#   them to an S3 bucket.
#
#   Source files matching Automatic_backup_*.tar in BACKUP_DIR are renamed to
#   the form YYYYMMDDThhmmss-home-assistant-automatic-backup-<release>.tar
#   and uploaded via 'aws s3 sync'.  Already-uploaded files are skipped.
#
#   Scheduler mode is triggered by any of: --cron, --cron-expression, or the
#   CRON_EXPRESSION environment variable.  In scheduler mode a crontab entry
#   is installed and supercronic is exec'd; output and exit status are those
#   of supercronic.  The spawned jobs run in CLI mode (no scheduling trigger).
#
#   Without any scheduling trigger the command runs one sync pass
#   synchronously and exits; output and exit status are those of
#   ha-offsite-backups itself.
#
#   Every env var listed below can be overridden by the corresponding CLI
#   flag.  CLI flags take precedence over environment values.
#
# OPTIONS
#   -h,--help                        Display this help text
#   -v,--version                     Display command version
#
#   Scheduler mode (any one triggers async/periodic execution):
#   -c,--cron                        Enter scheduler mode using CRON_EXPRESSION
#                                    (default: @daily)
#   --cron-expression EXPR           Enter scheduler mode with schedule EXPR
#                                    (env: CRON_EXPRESSION; implies --cron)
#
#   Source and destination:
#   -d,--backup-dir DIR              Directory containing HA backup files
#                                    (env: BACKUP_DIR; default: /backups)
#   -b,--bucket BUCKET               S3 bucket to sync backups to
#                                    (env: HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME,
#                                    fallback: AWS_S3_BUCKET_NAME)
#
#   Execution control:
#   --dryrun                         Enable dry-run; no uploads made
#                                    (env: DRYRUN; default: true)
#   --no-dryrun                      Disable dry-run; uploads are live
#   -y,--yes                         Skip the interactive confirmation
#                                    prompt when DRYRUN=false and stdin is
#                                    a tty (env: YES; default: false)
#
#   AWS configuration:
#   --aws-config FILE                AWS config file
#                                    (env: AWS_CONFIG_FILE;
#                                    default: /run/secrets/aws-config)
#   --aws-extra-args ARGS            Extra args appended to every aws call
#                                    (env: AWS_EXTRA_ARGS)
#
# ENVIRONMENT
#   AWS_CONFIG_FILE          AWS configuration file
#   AWS_EXTRA_ARGS           Additional aws CLI arguments
#   BACKUP_DIR               Source directory for HA backup files
#                            (default: /backups)
#   HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME / AWS_S3_BUCKET_NAME
#                            S3 bucket to sync backups to
#   CRON_EXPRESSION          Schedule for --cron mode (default: @daily)
#   DEBUG                    Enable bash -x tracing (default: false)
#   DRYRUN                   Dry-run mode — no uploads (default: true)
#   ENV                      Env-file path (default: ~/.env)
#   YES                      Skip confirmation prompt (default: false)

if command -v readlink >/dev/null 2>&1 && readlink -f "$(dirname "${0}")" >/dev/null 2>&1; then
    bindir=$(readlink -f "$(dirname "${0}")")
else
    bindir=$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd -P)
fi
echo "${PATH}" | grep -qF "${bindir}" || export PATH=${bindir}:${PATH}

# shellcheck disable=SC1091
# Allow tests to override the include dir via INCLUDE_DIR env var
source "${INCLUDE_DIR:-/usr/local/include}/common-functions"

ENV=${ENV:-${HOME:-/root}/.env}
# shellcheck disable=SC1090
[[ -r "${ENV}" ]] && source "${ENV}"

set -o errexit -o errtrace -o nounset -o pipefail
is_true "${DEBUG:=false}" && set -o xtrace -o verbose

# Allow tests to override command locations (mocks)
export AWS_CMD=${AWS_CMD:-aws}

VERSION_FILE=/usr/local/share/ha-offsite-backups/version

# ---------------------------------------------------------------------------
# Function definitions (lexical order)
# ---------------------------------------------------------------------------

function cleanup() {
    # Remove temporary work directories on exit.
    rm -rf "${WORKDIR:-}" >/dev/null 2>&1 || true
}

function confirm_live_run() {
    # Interactive confirmation gate for CLI mode with DRYRUN=false.
    # Skipped automatically when:
    #   - DRYRUN=true (no uploads will occur)
    #   - stdin is not a tty (scripted / Docker / CI context)
    #   - YES=true (--yes flag or env var)
    is_true "${DRYRUN}" && return 0
    [[ -t 0 ]] || return 0
    is_true "${YES}" && return 0

    warn "DRYRUN=false — this run will upload files to S3"
    echo "" >&2
    echo "  Bucket:     ${BUCKET}" >&2
    echo "  Source dir: ${BACKUP_DIR}" >&2
    echo "" >&2
    printf 'Type "yes" to proceed, or press Enter to abort: ' >&2
    local response
    read -r response
    echo "" >&2
    [[ "${response}" == "yes" ]] || error "aborted by user"
}

function run_scheduler() {
    # Enter scheduler mode: write env file, install crontab, exec supercronic.
    # CRON_EXPRESSION is intentionally omitted from the written env file so
    # that the supercronic-invoked ha-offsite-backups runs in CLI mode rather
    # than re-entering scheduler mode.
    # Usage:
    #   run_scheduler CRON_EXPR
    # Arguments:
    #   CRON_EXPR: cron schedule expression (e.g. "@daily", "0 4 * * *")
    local cron_expr="${1:?Need cron expression}"

    info "entering scheduler mode (${cron_expr})"

    # Validate bucket config before committing to background operation.
    [[ -n "${BUCKET}" ]] || \
        error "need to specify BUCKET to sync backups to"

    # Write the env file consumed by supercronic-invoked jobs.
    # Use printf '%q' for every value so that values containing quotes,
    # parentheses, braces, or other shell-special characters are safely escaped.
    # CRON_EXPRESSION is explicitly unset so that cron jobs sourcing this file
    # do not inherit the variable and re-enter scheduler mode.
    ENV=${ENV:-${HOME:-/root}/.env}
    touch "${ENV}"
    chmod 0600 "${ENV}"
    {
        printf 'export AWS_CONFIG_FILE=%q\n'  "${AWS_CONFIG_FILE}"
        printf 'export AWS_EXTRA_ARGS=%q\n'   "${AWS_EXTRA_ARGS}"
        printf 'export BACKUP_DIR=%q\n'        "${BACKUP_DIR}"
        printf 'export BUCKET=%q\n'            "${BUCKET}"
        printf 'export DEBUG=%q\n'             "${DEBUG}"
        printf 'export DRYRUN=%q\n'            "${DRYRUN}"
        printf 'unset CRON_EXPRESSION\n'
    } > "${ENV}"
    info "wrote env file ${ENV}"
    info < "${ENV}"

    # Install the crontab entry.
    # supercronic writes job stdout/stderr directly to its own stdout/stderr
    # (captured by docker logs), so no explicit output redirect is needed.
    local cmd=/usr/local/bin/ha-offsite-backups
    info "installing cron entry: ${cron_expr} ${cmd}"
    local _crontab
    _crontab="/var/spool/cron/crontabs/$(id -un)"
    printf '%s %s\n' "${cron_expr}" "${cmd}" > "${_crontab}"
    chmod 0644 "${_crontab}"
    info "crontab: $(cat "${_crontab}")"

    info "handing off to supercronic"
    # -no-reap: suppress PID 1 zombie-reaping; the cron job subprocess is
    # short-lived and Docker cleans up on container exit, so this is safe.
    exec supercronic -no-reap "${_crontab}"
}

function show_help() {
    # Display command usage help.
    cat <<'EOF'
Usage: ha-offsite-backups [options]

ha-offsite-backups renames Home Assistant automated backup files to ISO-datetime
lexical order and syncs them to an S3 bucket via 'aws s3 sync'.

Source files matching Automatic_backup_*.tar in BACKUP_DIR are renamed to:
  YYYYMMDDThhmmss-home-assistant-automatic-backup-<release>.tar
Files already present in the bucket are skipped (incremental sync).

Scheduler mode is triggered by --cron, --cron-expression, or the
CRON_EXPRESSION environment variable.  In scheduler mode a crontab entry is
installed and supercronic is exec'd.  Without a scheduling trigger, the
command runs one sync pass synchronously and exits.

Options:
  -h,--help                        Display this help text
  -v,--version                     Display command version

  Scheduling (any one triggers async/periodic execution via supercronic):
  -c,--cron                        Enter scheduler mode using CRON_EXPRESSION
                                   (default: @daily)
  --cron-expression EXPR           Scheduler mode; use EXPR as the schedule
                                   (env: CRON_EXPRESSION; implies --cron)

  Source and destination:
  -d,--backup-dir DIR              Directory containing HA backup files
                                   (env: BACKUP_DIR; default: /backups)
  -b,--bucket BUCKET               S3 bucket to sync backups to (env: BUCKET)

  Execution control:
  --dryrun                         Enable dry-run; no uploads made
                                   (env: DRYRUN; default: true)
  --no-dryrun                      Disable dry-run; uploads are live
  -y,--yes                         Skip the interactive confirmation
                                   prompt when DRYRUN=false and stdin
                                   is a tty (env: YES; default: false)

  AWS configuration:
  --aws-config FILE                AWS config file
                                   (env: AWS_CONFIG_FILE;
                                   default: /run/secrets/aws-config)
  --aws-extra-args ARGS            Extra args appended to every aws call
                                   (env: AWS_EXTRA_ARGS)

Dry-run is enabled by default.  Pass --no-dryrun (or set DRYRUN=false) to
perform actual uploads.

Examples:
  # One-shot dry-run sync (CLI mode):
  ha-offsite-backups --bucket my-backups --backup-dir /config/backups

  # One-shot live sync (CLI mode):
  ha-offsite-backups --bucket my-backups --backup-dir /backups --no-dryrun

  # Scheduler mode — daily at midnight (default schedule):
  ha-offsite-backups --cron --bucket my-backups

  # Scheduler mode — custom schedule via flag (implies --cron):
  ha-offsite-backups --cron-expression "0 4 * * *" \
      --bucket my-backups --no-dryrun

  # Scheduler mode — custom schedule via env var (implies --cron):
  CRON_EXPRESSION="0 4 * * *" ha-offsite-backups --bucket my-backups

EOF
    local version
    version=$(show_version)
    if [[ "${version}" != "unknown" ]]; then
        printf '[1121citrus/ha-offsite-backups %s]\n' "${version}"
    fi
}

function show_version() {
    # Display the installed version of ha-offsite-backups.
    cat "${VERSION_FILE}" 2>/dev/null || echo "unknown"
}

function sync_backups() {
    # Rename HA backup files to ISO-datetime format and sync to S3.
    # Usage:
    #   sync_backups BUCKET
    # Arguments:
    #   BUCKET: S3 bucket name to sync to
    local bucket="${1:?Need bucket}"
    local uri="s3://${bucket}"

    # Build aws CLI extra args; add --dryrun when DRYRUN=true.
    local awsargs="${AWS_EXTRA_ARGS:-}"
    is_true "${DRYRUN}" && awsargs="${awsargs} --dryrun"

    info "begin sync '${BACKUP_DIR}' to '${uri}'"

    # Create symlinks in WORKDIR with ISO-datetime names pointing to the
    # original backup files.  aws s3 sync follows symlinks by default, so
    # the renamed names appear as the S3 object keys.
    # If BACKUP_DIR doesn't exist, there are no backups to sync (noop).
    if [[ -d "${BACKUP_DIR}" ]]; then
        local file object_name
        find "${BACKUP_DIR}" -maxdepth 1 -type f \
                -name 'Automatic_backup_*.tar' | \
        while read -r file; do
            object_name=$(xform-backup-name "${file}")
            info "renaming '$(basename "${file}")' → '${object_name}'"
            ln -sf "${file}" "${WORKDIR}/${object_name}"
        done
    fi

    # shellcheck disable=SC2086
    info "running '${AWS_CMD} s3 sync ${awsargs} ${WORKDIR} ${uri}'"
    # shellcheck disable=SC2086
    ("${AWS_CMD}" s3 sync ${awsargs} "${WORKDIR}" "${uri}" \
        || (error "${AWS_CMD} s3 sync exited with status $?" || true)) 2>&1 | info

    info "finish sync '${BACKUP_DIR}' to '${uri}'"

    # Write success marker for the healthcheck (scheduler mode).
    local marker="${HEALTHCHECK_SUCCESS_FILE:-/tmp/.ha-offsite-backups-success}"
    touch "${marker}" 2>/dev/null || true
}

function xform-backup-name() {
    # Transform an HA backup filename to ISO-datetime lexical order.
    # Usage:
    #   xform-backup-name FILENAME
    # Arguments:
    #   FILENAME: path or basename of an HA backup file, e.g.
    #             Automatic_backup_2025.6.3_2025-07-06_05.35_00004800.tar
    # Output (stdout):
    #   Renamed filename, e.g.
    #   20250706T053500-home-assistant-automatic-backup-2025.6.3.tar
    local file="${1:?Need filename}"
    local f
    f=$(basename "${file}")
    local base ext date time
    # Fields 1-3 (Automatic_backup_<release>) → lower-kebab-case
    base=$(echo "${f}" | cut -d_ -f-3 | tr '[:upper:]' '[:lower:]' | tr _ -)
    # File extension (last component after the final '.')
    ext=$(echo "${f}" | rev | cut -d. -f1 | rev)
    # Field 4 (YYYY-MM-DD) → YYYYMMDD
    date=$(echo "${f}" | cut -d_ -f4 | tr -d -- -)
    # Fields 5+ (HH.MM_nanoseconds.tar) → first 6 digits = HHMMSS
    time=$(echo "${f}" | cut -d_ -f5- | tr -d '._' | cut -c -6)
    echo "${date}T${time}-home-assistant-${base}.${ext}"
}

# ---------------------------------------------------------------------------
# Defaults from environment (CLI flags below override these).
# ---------------------------------------------------------------------------
export BACKUP_DIR="${HA_OFFSITE_BACKUPS_BACKUP_DIR:-${BACKUP_DIR:-/backups}}"
export BUCKET="${HA_OFFSITE_BACKUPS_AWS_S3_BUCKET_NAME:-${AWS_S3_BUCKET_NAME:-}}"
export AWS_CONFIG_FILE="${HA_OFFSITE_BACKUPS_AWS_CONFIG_FILE:-${AWS_CONFIG_FILE:-/run/secrets/aws-config}}"
export AWS_EXTRA_ARGS="${HA_OFFSITE_BACKUPS_AWS_EXTRA_ARGS:-${AWS_EXTRA_ARGS:-}}"
# Capture whether CRON_EXPRESSION was set in the environment before applying
# the default — a pre-set CRON_EXPRESSION implies scheduler mode.
_cron_expression_from_env=false
[[ -v HA_OFFSITE_BACKUPS_CRON_EXPRESSION || -v CRON_EXPRESSION ]] && _cron_expression_from_env=true
export CRON_EXPRESSION="${HA_OFFSITE_BACKUPS_CRON_EXPRESSION:-${CRON_EXPRESSION:-@daily}}"
export DRYRUN="${HA_OFFSITE_BACKUPS_DRYRUN:-${DRYRUN:-true}}"
YES="${HA_OFFSITE_BACKUPS_YES:-${YES:-false}}"

# ---------------------------------------------------------------------------
# CLI argument parsing — flags override env defaults above.
# ---------------------------------------------------------------------------
CRON_MODE=false

while [[ $# -gt 0 ]]; do
    case "${1}" in
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--version)
            show_version
            exit 0
            ;;
        -c|--cron)
            CRON_MODE=true
            ;;
        --cron-expression)
            [[ $# -ge 2 ]] || error "option '${1}' requires an argument"
            CRON_EXPRESSION="${2}"; CRON_MODE=true; shift
            ;;
        -d|--backup-dir)
            [[ $# -ge 2 ]] || error "option '${1}' requires an argument"
            BACKUP_DIR="${2}"; shift
            ;;
        -b|--bucket)
            [[ $# -ge 2 ]] || error "option '${1}' requires an argument"
            BUCKET="${2}"; shift
            ;;
        --aws-config)
            [[ $# -ge 2 ]] || error "option '${1}' requires an argument"
            AWS_CONFIG_FILE="${2}"; shift
            ;;
        --aws-extra-args)
            [[ $# -ge 2 ]] || error "option '${1}' requires an argument"
            AWS_EXTRA_ARGS="${2}"; shift
            ;;
        --dryrun)
            DRYRUN=true
            ;;
        --no-dryrun)
            DRYRUN=false
            ;;
        --yes|-y)
            YES=true
            ;;
        --)
            shift; break
            ;;
        -*)
            error "${EXIT_USAGE}" "unknown option: '${1}'"
            ;;
        *)
            error "${EXIT_USAGE}" "unexpected argument: '${1}'"
            ;;
    esac
    shift
done

export BUCKET CRON_EXPRESSION

# CRON_EXPRESSION set in the environment (not just the compiled-in default)
# implies scheduler mode, same as passing --cron or --cron-expression.
if "${_cron_expression_from_env}"; then
    CRON_MODE=true
fi

# ---------------------------------------------------------------------------
# Dispatch: scheduler mode or CLI mode.
# ---------------------------------------------------------------------------

if [[ "${CRON_MODE}" == "true" ]]; then
    # run_scheduler writes the env file and execs supercronic — never returns.
    run_scheduler "${CRON_EXPRESSION}"
fi

# CLI mode: run one sync pass and exit.
[[ -n "${BUCKET}" ]] || \
    error "need to specify BUCKET to sync backups to"

confirm_live_run

WORKDIR=$(mktemp -d)
trap cleanup EXIT

info "begin sync from '${BACKUP_DIR}' to 's3://${BUCKET}'"
sync_backups "${BUCKET}"
info "completed sync from '${BACKUP_DIR}' to 's3://${BUCKET}'"
cleanup
